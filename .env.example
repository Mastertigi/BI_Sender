# ─────────────── Entra ID / Azure AD (Service Principal) ───────────────
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Use UM dos dois: secret (dev) OU certificado (prod recomendado)
AZURE_CLIENT_SECRET=super-secret-value
# AZURE_CLIENT_CERT_THUMBPRINT=
# AZURE_CLIENT_CERT_PATH=/secrets/sp.pem

# ─────────────── Scopes (App-Only / .default) ───────────────
POWERBI_SCOPE=https://analysis.windows.net/powerbi/api/.default
GRAPH_SCOPE=https://graph.microsoft.com/.default

# ─────────────── Endpoints base ───────────────
POWERBI_API_BASE=https://api.powerbi.com/v1.0/myorg
GRAPH_API_BASE=https://graph.microsoft.com/v1.0

# Identidade (mailbox) usada para enviar e-mail via /users/{id}/sendMail
GRAPH_SENDER_USER_ID=automacao.bi@empresa.com.br

# ─────────────── Banco de dados ───────────────
DATABASE_URL=postgresql+psycopg2://bi_notify:bi_notify@db:5432/bi_notify

# ─────────────── Celery / Redis ───────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─────────────── Segurança da API interna ───────────────
# Token compartilhado que o webhook (ex.: gatilho do Dataflow) deve enviar no header X-Webhook-Token
WEBHOOK_SHARED_SECRET=troque-este-valor

# ─────────────── CORS (frontend) ───────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────── Tuning de exportação ───────────────
EXPORT_POLL_INITIAL_DELAY=5
EXPORT_POLL_MAX_DELAY=60
EXPORT_POLL_TIMEOUT=1800
